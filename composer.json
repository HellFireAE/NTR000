{
    "name": "jonathanhfmills/website-wp-bedrock-ntara-test",
    "type": "project",
    "homepage": "https://github.com/jonathanhfmills/website-wp-bedrock-ntara-test",
    "authors": [
        {
            "name": "Jonathan Mills",
            "homepage": "https://github.com/jonathanhfmills"
        }
    ],
    "repositories": [
        {
            "type": "vcs",
            "url": "https://github.com/jonathanhfmills/website-wp-theme-ntara-test"
        },
        {
            "name": "wp-packages",
            "type": "composer",
            "url": "https://repo.wp-packages.org"
        }
    ],
    "require": {
        "roots/bedrock": "^1.30.1",
        "roots/wordpress": "^6.9.4",
        "wp-theme/twentytwentyfive": "1.4",
        "wp-plugin/woocommerce": "^10.6.2",
        "jonathanhfmills/website-wp-theme-ntara-test": "dev-main"
    },
    "config": {
        "optimize-autoloader": true,
        "allow-plugins": {
            "composer/installers": true,
            "roots/wordpress-core-installer": true
        }
    },
    "prefer-stable": true,
    "minimum-stability": "dev",
    "extra": {
        "force-unix-separator": true,
        "installer-paths": {
        "web/app/mu-plugins/{$name}/": ["type:wordpress-muplugin"],
        "web/app/plugins/{$name}/": ["type:wordpress-plugin"],
        "web/app/themes/{$name}/": ["type:wordpress-theme"]
        },
        "wordpress-install-dir": "web/wp"
    },
    "scripts": {
        "test": [
          "phpcs"
        ],
        "post-install-cmd": [
            "@composer install --no-dev --working-dir=web/app/themes/website-wp-theme-ntara-test",
            "bash .devcontainer/scripts/install.sh"
        ],
        "post-update-cmd": [
            "@composer install --no-dev --working-dir=web/app/themes/website-wp-theme-ntara-test"
        ]
    }
}
